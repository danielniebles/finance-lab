generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Module 1: Expense Tracker ────────────────────────────────────────────────

enum BatchStatus {
  IN_PROGRESS
  FINAL
}

model ImportBatch {
  id           String        @id @default(cuid())
  filename     String
  importedAt   DateTime      @default(now())
  periodStart  DateTime
  periodEnd    DateTime
  month        Int // 1–12
  year         Int
  status       BatchStatus   @default(FINAL)
  transactions Transaction[]

  @@unique([month, year])
}

model MoneyLoverCategory {
  id           String           @id @default(cuid())
  name         String           @unique
  mapping      CategoryMapping?
  transactions Transaction[]
}

model AppCategory {
  id                String             @id @default(cuid())
  name              String             @unique
  // Independent, nullable style overrides (Category icon & color picker).
  // Null = auto-derive from name via getCategoryStyle(); non-null = explicit
  // override. icon is a key into ICON_REGISTRY, color is a PALETTE key —
  // both validated against closed key lists at the action layer, not here.
  icon              String?
  color             String?
  mappings          CategoryMapping[]
  budgetItems       BudgetItem[]
  transactions      Transaction[]
  counterpartyRules CounterpartyRule[]
}

model BudgetItem {
  id            String      @id @default(cuid())
  appCategoryId String
  appCategory   AppCategory @relation(fields: [appCategoryId], references: [id], onDelete: Cascade)
  name          String
  amount        Float
  budgetType    BudgetType
}

model CategoryMapping {
  id                   String             @id @default(cuid())
  moneyLoverCategoryId String             @unique
  moneyLoverCategory   MoneyLoverCategory @relation(fields: [moneyLoverCategoryId], references: [id])
  appCategoryId        String
  appCategory          AppCategory        @relation(fields: [appCategoryId], references: [id])
}

enum TransactionSource {
  MONEYLOVER
  MANUAL
}

model Transaction {
  id                   String              @id @default(cuid())
  externalId           Int?
  date                 DateTime
  amount               Float
  wallet               String
  note                 String?
  batchId              String?
  batch                ImportBatch?        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  moneyLoverCategoryId String?
  moneyLoverCategory   MoneyLoverCategory? @relation(fields: [moneyLoverCategoryId], references: [id])
  appCategoryId        String?
  appCategory          AppCategory?        @relation(fields: [appCategoryId], references: [id])
  source               TransactionSource   @default(MONEYLOVER)
  // Wallet partition this transaction belongs to (ADR-036/037). Nullable during
  // migration; `wallet` (the legacy string label) is kept as a fallback + audit trail.
  walletId             String?
  walletRef            Wallet?             @relation(fields: [walletId], references: [id])
}

enum BudgetType {
  FIXED
  VARIABLE
}

enum RuleMatchType {
  ACCOUNT
  MERCHANT
  SENDER
  KEYWORD
}

enum RuleDirection {
  EXPENSE
  INCOME
  ANY
}

model CounterpartyRule {
  id             String        @id @default(cuid())
  matchType      RuleMatchType
  matchValue     String // normalized on write: digits-only for ACCOUNT, trimmed+uppercased for MERCHANT/SENDER/KEYWORD
  direction      RuleDirection @default(ANY)
  appCategoryId  String
  appCategory    AppCategory   @relation(fields: [appCategoryId], references: [id])
  wallet         String // wallet LABEL to route to — overrides the message's stated account
  autoRecord     Boolean       @default(true)
  recurring      Boolean       @default(false)
  expectedAmount Float?
  notes          String?
  matchCount     Int           @default(0)
  lastMatchedAt  DateTime?
  createdAt      DateTime      @default(now())

  @@index([matchType, matchValue])
}

// ─── Module 2: Installment Tracker ────────────────────────────────────────────

model CreditCard {
  id                String        @id @default(cuid())
  name              String        @unique
  creditLimit       Float?
  billingClosingDay Int?
  paymentDueDay     Int?
  color             String?
  installments      Installment[]
}

model Installment {
  id                  String               @id @default(cuid())
  description         String
  totalAmount         Float
  numInstallments     Int
  monthlyAmount       Float // stored via computeMonthlyAmount()
  monthlyInterestRate Float? // null = no interest; stored as % m.v. (mensual vencido)
  startDate           DateTime // date of first payment (e.g. 2025-11-10)
  notes               String?
  createdAt           DateTime             @default(now())
  payments            InstallmentPayment[]
  cardId              String?
  card                CreditCard?          @relation(fields: [cardId], references: [id], onDelete: SetNull)
  debtorId            String?
  debtor              Debtor?              @relation(fields: [debtorId], references: [id], onDelete: SetNull)
  fundingAccountId    String?
  fundingAccount      SavingsAccount?      @relation("InstallmentFunding", fields: [fundingAccountId], references: [id], onDelete: SetNull)
}

model InstallmentPayment {
  id             String      @id @default(cuid())
  installmentId  String
  installment    Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  installmentNum Int // 1-based, which payment in the sequence
  paidAt         DateTime
}

// ─── Module 3: Loan / Debt Tracker ────────────────────────────────────────────

model SavingsAccount {
  id                 String         @id @default(cuid())
  name               String         @unique
  accountType        AccountType
  color              String? // hex color for UI dot
  entries            AccountEntry[]
  loansGiven         Loan[]
  transfersFrom      Transfer[]     @relation("TransferFrom")
  transfersTo        Transfer[]     @relation("TransferTo")
  fundedInstallments Installment[]  @relation("InstallmentFunding")
  vaultEntriesFunded VaultEntry[]   @relation("VaultFundingSource")

  // ─── Wallets (ADR-036/037, Milestone C1) ─────────────────────────────────
  wallets         Wallet[] @relation("AccountWallets")
  // Target wallet for account-level loan/vault/transfer/adjustment flows.
  savingsWalletId String?
  savingsWallet   Wallet?  @relation("AccountSavingsWallet", fields: [savingsWalletId], references: [id])
  // Default wallet for ambient transactions whose label only names the institution.
  defaultWalletId String?
  defaultWallet   Wallet?  @relation("AccountDefaultWallet", fields: [defaultWalletId], references: [id])
}

/// Envelope partition inside a SavingsAccount (institution). ADR-036.
/// isSavings gates savings/Loans-surface membership (debit/daily = false);
/// includeInAvailable (moved down from SavingsAccount) gates liquidity within
/// savings (Protección/investments = false). A wallet counts toward the
/// liquidity KPI iff isSavings && includeInAvailable.
model Wallet {
  id                 String   @id @default(cuid())
  accountId          String
  account            SavingsAccount @relation("AccountWallets", fields: [accountId], references: [id], onDelete: Cascade)
  name               String
  color              String?
  sortOrder          Int      @default(0)
  isSavings          Boolean  @default(true)
  includeInAvailable Boolean  @default(true)
  openingBalance     Float    @default(0) // reconciliation anchor (ADR-037)
  openingDate        DateTime // the balance "epoch" — only flows on/after this date move the balance

  transactions       Transaction[]
  loans              Loan[]
  vaultEntriesFunded VaultEntry[]     @relation("VaultFundingWallet")
  savingsWalletFor   SavingsAccount[] @relation("AccountSavingsWallet")
  defaultWalletFor   SavingsAccount[] @relation("AccountDefaultWallet")

  @@unique([accountId, name])
}

enum AccountType {
  BANK
  DIGITAL
  PENSION
}

model AccountEntry {
  id        String         @id @default(cuid())
  accountId String
  account   SavingsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      EntryType
  amount    Float // positive or negative
  date      DateTime
  notes     String?
}

enum EntryType {
  INITIAL
  ADJUSTMENT
}

model Transfer {
  id            String         @id @default(cuid())
  fromAccountId String
  fromAccount   SavingsAccount @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     SavingsAccount @relation("TransferTo", fields: [toAccountId], references: [id])
  amount        Float
  date          DateTime
  notes         String?
}

model Debtor {
  id           String        @id @default(cuid())
  name         String        @unique
  notes        String?
  loans        Loan[]
  installments Installment[]
}

model Loan {
  id         String         @id @default(cuid())
  debtorId   String
  debtor     Debtor         @relation(fields: [debtorId], references: [id])
  accountId  String
  account    SavingsAccount @relation(fields: [accountId], references: [id])
  amount     Float
  date       DateTime
  expectedBy DateTime?
  notes      String?
  payments   LoanPayment[]
  createdAt  DateTime       @default(now())
  // Source wallet (ADR-036/037). C1 defaults it to the account's savingsWalletId;
  // per-transaction selection is a C2 follow-up.
  walletId   String?
  wallet     Wallet?        @relation(fields: [walletId], references: [id])
}

model LoanPayment {
  id     String   @id @default(cuid())
  loanId String
  loan   Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount Float
  date   DateTime
  notes  String?
}

// ─── Module 4: Vaults ─────────────────────────────────────────────────────────

enum VaultKind {
  MANDATORY
  LEISURE
}

enum VaultGoalType {
  FIXED_DEADLINE
  OPEN_ENDED
  RECURRING
}

model Vault {
  id                String             @id @default(cuid())
  name              String             @unique
  kind              VaultKind          @default(LEISURE)
  goalType          VaultGoalType      @default(FIXED_DEADLINE)
  targetAmount      Float? // required when goalType = FIXED_DEADLINE
  targetDate        DateTime? // required when goalType = FIXED_DEADLINE
  color             String?
  notes             String?
  archivedAt        DateTime? // set when goal met/abandoned; keeps history
  createdAt         DateTime           @default(now())
  entries           VaultEntry[]
  recurringExpenses RecurringExpense[] @relation("VaultRecurring")
}

model VaultEntry {
  id              String          @id @default(cuid())
  vaultId         String
  vault           Vault           @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  amount          Float // positive = contribution, negative = withdrawal
  date            DateTime        @default(now())
  notes           String?
  createdAt       DateTime        @default(now())
  sourceAccountId String?
  sourceAccount   SavingsAccount? @relation("VaultFundingSource", fields: [sourceAccountId], references: [id], onDelete: SetNull)
  // Source wallet (ADR-036/037), alongside the existing sourceAccountId (kept for
  // backward-compat — derivable from the wallet). C1 defaults it to the account's
  // savingsWalletId.
  sourceWalletId  String?
  sourceWallet    Wallet?         @relation("VaultFundingWallet", fields: [sourceWalletId], references: [id], onDelete: SetNull)
}

// ─── Module 5: Recurring Expenses ────────────────────────────────────────────

model RecurringExpense {
  id              String                    @id @default(cuid())
  name            String
  estimatedAmount Float
  cadenceMonths   Int
  nextDueDate     DateTime
  category        String?
  fundingVaultId  String?
  fundingVault    Vault?                    @relation("VaultRecurring", fields: [fundingVaultId], references: [id], onDelete: SetNull)
  active          Boolean                   @default(true)
  notes           String?
  createdAt       DateTime                  @default(now())
  payments        RecurringExpensePayment[]
}

model RecurringExpensePayment {
  id                 String           @id @default(cuid())
  recurringExpenseId String
  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  amount             Float
  dueDate            DateTime
  paidAt             DateTime         @default(now())
  vaultEntryId       String?
  notes              String?
}

// ─── Milestone 5 — AI Advisor ─────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  role      String // "user" | "assistant"
  content   String
  channel   String? // "web" | "telegram" | "shortcut" — null = legacy/unknown
  createdAt DateTime @default(now())
}

model PendingProposal {
  id         String    @id @default(cuid())
  action     String
  params     Json
  title      String
  status     String    @default("pending") // pending | approved | dismissed | expired | undone
  channel    String // "web" | "telegram"
  editable   Json? // option list for index→id resolution (editable proposal fields; unused until the Telegram/tool pass lands)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}
